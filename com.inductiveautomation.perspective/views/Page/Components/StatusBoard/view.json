{
  "custom": {
    "themePrimaryText": "#111827",
    "themeMutedText": "#6b7280"
  },
  "params": {},
  "propConfig": {
    "custom.themePrimaryText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#f3f4f6\"\n\treturn \"#111827\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeMutedText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#9ca3af\"\n\treturn \"#6b7280\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    }
  },
  "props": {
    "defaultSize": {
      "height": 1200,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "SystemStatusTitle"
        },
        "position": {
          "basis": "34px",
          "shrink": 0
        },
        "props": {
          "style": {
            "fontSize": "22px",
            "fontWeight": "700",
            "paddingLeft": "4px",
            "paddingTop": "6px"
          },
          "text": "System Status"
        },
        "type": "ia.display.label",
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "path": "view.custom.themePrimaryText"
              },
              "type": "property"
            }
          }
        }
      },
      {
        "meta": {
          "name": "SummaryCards"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "path": "Page/Components/StatusSummaryCard",
          "wrap": "wrap"
        },
        "type": "ia.display.flex-repeater",
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "expression": "now(2000)"
              },
              "transforms": [
                {
                  "code": "\timport MainController.State.StatusBoardStore\n\treturn MainController.State.StatusBoardStore.summaryCards()",
                  "type": "script"
                }
              ],
              "type": "expr"
            }
          }
        }
      },
