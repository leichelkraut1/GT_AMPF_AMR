{
  "custom": {},
  "params": {
    "message": "",
    "status": "",
    "subsystem": ""
  },
  "propConfig": {
    "custom.themeMutedText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#9ca3af\"\n\treturn \"#6b7280\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themePrimaryText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#f3f4f6\"\n\treturn \"#111827\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceAltBg": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#1f2937\"\n\treturn \"#f3f4f6\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceBorder": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"1px solid #374151\"\n\treturn \"1px solid #d1d5db\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "params.message": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.status": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.subsystem": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 70,
      "width": 214
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Subsystem"
        },
        "position": {
          "basis": "18px",
          "shrink": 0
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "path": "view.custom.themeMutedText"
              },
              "type": "property"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.subsystem"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "11px",
            "fontWeight": "700",
            "textTransform": "uppercase"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Status"
        },
        "position": {
          "basis": "24px",
          "shrink": 0
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "expression": "if({view.params.status} \u003d \"Error\", \"#b91c1c\", if({view.params.status} \u003d \"Warn\", \"#b45309\", if({view.params.status} \u003d \"Healthy\", \"#166534\", if({view.params.status} \u003d \"Idle\", \"#475569\", {view.custom.themePrimaryText}))))"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.status"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "17px",
            "fontWeight": "700"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.backgroundColor": {
        "binding": {
          "config": {
            "path": "view.custom.themeSurfaceAltBg"
          },
          "type": "property"
        }
      },
      "props.style.border": {
        "binding": {
          "config": {
            "path": "view.custom.themeSurfaceBorder"
          },
          "type": "property"
        }
      },
      "props.style.borderLeft": {
        "binding": {
          "config": {
            "expression": "\"4px solid \" + if({view.params.status} \u003d \"Error\", \"#b91c1c\", if({view.params.status} \u003d \"Warn\", \"#b45309\", if({view.params.status} \u003d \"Healthy\", \"#166534\", if({view.params.status} \u003d \"Idle\", \"#475569\", \"#2563eb\"))))"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {
        "borderRadius": "10px",
        "marginBottom": "10px",
        "marginRight": "12px",
        "minHeight": "65px",
        "padding": "10px"
      }
    },
    "type": "ia.container.flex"
  }
}