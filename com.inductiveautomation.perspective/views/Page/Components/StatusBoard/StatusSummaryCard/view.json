{
  "custom": {},
  "params": {
    "detail": "",
    "title": "",
    "tone": "Info",
    "value": ""
  },
  "propConfig": {
    "custom.themeMutedText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#9ca3af\"\n\treturn \"#6b7280\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themePrimaryText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#f3f4f6\"\n\treturn \"#111827\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceBg": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#111827\"\n\treturn \"#f9fafb\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceBorder": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"1px solid #374151\"\n\treturn \"1px solid #d1d5db\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "params.detail": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.title": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tone": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.value": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 75,
      "width": 214
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Title"
        },
        "position": {
          "basis": "18px",
          "shrink": 0
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "path": "view.custom.themeMutedText"
              },
              "type": "property"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.title"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "11px",
            "fontWeight": "700",
            "textTransform": "uppercase"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Value"
        },
        "position": {
          "basis": "26px",
          "shrink": 0
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "expression": "if({view.params.tone} \u003d \"Error\", \"#b91c1c\", if({view.params.tone} \u003d \"Warn\", \"#b45309\", if({view.params.tone} \u003d \"Healthy\", \"#166534\", if({view.params.tone} \u003d \"Idle\", \"#475569\", \"#2563eb\"))))"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.value"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "17px",
            "fontWeight": "700",
            "lineHeight": "1.1",
            "whiteSpace": "normal"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.backgroundColor": {
        "binding": {
          "config": {
            "path": "view.custom.themeSurfaceBg"
          },
          "type": "property"
        }
      },
      "props.style.border": {
        "binding": {
          "config": {
            "path": "view.custom.themeSurfaceBorder"
          },
          "type": "property"
        }
      },
      "props.style.borderLeft": {
        "binding": {
          "config": {
            "expression": "\"6px solid \" + if({view.params.tone} \u003d \"Error\", \"#b91c1c\", if({view.params.tone} \u003d \"Warn\", \"#b45309\", if({view.params.tone} \u003d \"Healthy\", \"#166534\", if({view.params.tone} \u003d \"Idle\", \"#475569\", \"#2563eb\"))))"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {
        "borderRadius": "12px",
        "boxShadow": "0 10px 24px rgba(0,0,0,0.08)",
        "marginBottom": "10px",
        "marginRight": "14px",
        "minHeight": 70,
        "padding": "10px"
      }
    },
    "type": "ia.container.flex"
  }
}