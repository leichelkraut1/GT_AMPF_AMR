                    "binding": {
                      "config": {
                        "fallbackDelay": 2.5,
                        "mode": "direct",
                        "tagPath": "[Otto_FleetManager]Fleet/System/ServerStatus"
                      },
                      "transforms": [
                        {
                          "expression": "if(isNull({value}) || len(toStr({value})) = 0, \"-\", toStr({value}))",
                          "type": "expression"
                        }
                      ],
                      "type": "tag"
                    }
                  }
                },
                "props": {
                  "style": {
                    "fontSize": "22px",
                    "fontWeight": "700",
                    "whiteSpace": "normal"
                  }
                },
                "type": "ia.display.label"
