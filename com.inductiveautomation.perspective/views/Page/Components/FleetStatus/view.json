      {
        "meta": {
          "name": "ContainerCards"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "expression": "now(3000)"
              },
              "transforms": [
                {
                  "code": "\tdef _rowseq(path):\n\t\treturn system.tag.browse(path).getResults()\n\n\tdef _rowseq_val(row, key, default\u003dNone):\n\t\tif isinstance(row, dict):\n\t\t\treturn row.get(key, default)\n\t\tgetter \u003d getattr(row, \"get\", None)\n\t\tif getter is not None:\n\t\t\ttry:\n\t\t\t\treturn getter(key)\n\t\t\texcept Exception:\n\t\t\t\tpass\n\t\treturn getattr(row, key, default)\n\n\tdef _is_udt(row):\n\t\ttag_type \u003d str(_rowseq_val(row, \"tagType\", \"\") or \"\").lower()\n\t\treturn \"udtinstance\" in tag_type\n\n\tdef _fullpath(row):\n\t\treturn str(_rowseq_val(row, \"fullPath\", \"\") or \"\")\n\n\tplace_rows \u003d [row for row in _rowseq(\"[Otto_FleetManager]Fleet/Places\") if _is_udt(row)]\n\trobot_rows \u003d [row for row in _rowseq(\"[Otto_FleetManager]Fleet/Robots\") if _is_udt(row)]\n\tcontainer_rows \u003d [row for row in _rowseq(\"[Otto_FleetManager]Fleet/Containers\") if _is_udt(row)]\n\n\tplace_reads \u003d []\n\tfor row in place_rows:\n\t\tpath \u003d _fullpath(row)\n\t\tplace_reads.extend([path + \"/ID\", path + \"/Name\"])\n\tplace_values \u003d system.tag.readBlocking(place_reads) if place_reads else []\n\tplace_by_id \u003d {}\n\tfor index, row in enumerate(place_rows):\n\t\toffset \u003d index * 2\n\t\tplace_id \u003d str(place_values[offset].value or \"\") if offset \u003c len(place_values) and place_values[offset].quality.isGood() else \"\"\n\t\tplace_name \u003d str(place_values[offset + 1].value or \"\") if offset + 1 \u003c len(place_values) and place_values[offset + 1].quality.isGood() else \"\"\n\t\tif place_id:\n\t\t\tplace_by_id[place_id] \u003d place_name or place_id\n\n\trobot_reads \u003d []\n\tfor row in robot_rows:\n\t\tpath \u003d _fullpath(row)\n\t\trobot_reads.append(path + \"/ID\")\n\trobot_values \u003d system.tag.readBlocking(robot_reads) if robot_reads else []\n\trobot_by_id \u003d {}\n\tfor index, row in enumerate(robot_rows):\n\t\trobot_id \u003d str(robot_values[index].value or \"\") if index \u003c len(robot_values) and robot_values[index].quality.isGood() else \"\"\n\t\trobot_name \u003d str(_rowseq_val(row, \"name\", \"\") or \"\")\n\t\tif robot_id:\n\t\t\trobot_by_id[robot_id] \u003d robot_name or robot_id\n\n\tcontainer_reads \u003d []\n\tfor row in container_rows:\n\t\tpath \u003d _fullpath(row)\n\t\tcontainer_reads.extend([\n\t\t\tpath + \"/ID\",\n\t\t\tpath + \"/ContainerType\",\n\t\t\tpath + \"/State\",\n\t\t\tpath + \"/Place\",\n\t\t\tpath + \"/Robot\",\n\t\t])\n\tcontainer_values \u003d system.tag.readBlocking(container_reads) if container_reads else []\n\n\tinstances \u003d []\n\tfor index, row in enumerate(container_rows):\n\t\toffset \u003d index * 5\n\t\tcontainer_id \u003d str(container_values[offset].value or \"\") if offset \u003c len(container_values) and container_values[offset].quality.isGood() else \"\"\n\t\tcontainer_type \u003d str(container_values[offset + 1].value or \"\") if offset + 1 \u003c len(container_values) and container_values[offset + 1].quality.isGood() else \"\"\n\t\tstate \u003d str(container_values[offset + 2].value or \"\") if offset + 2 \u003c len(container_values) and container_values[offset + 2].quality.isGood() else \"\"\n\t\tplace_id \u003d str(container_values[offset + 3].value or \"\") if offset + 3 \u003c len(container_values) and container_values[offset + 3].quality.isGood() else \"\"\n\t\trobot_id \u003d str(container_values[offset + 4].value or \"\") if offset + 4 \u003c len(container_values) and container_values[offset + 4].quality.isGood() else \"\"\n\n\t\tif place_id and place_id in place_by_id:\n\t\t\tlocation_label \u003d \"Place: {}\".format(place_by_id[place_id])\n\t\telif place_id:\n\t\t\tlocation_label \u003d \"Place: {}\".format(place_id)\n\t\telif robot_id and robot_id in robot_by_id:\n\t\t\tlocation_label \u003d \"Robot: {}\".format(robot_by_id[robot_id])\n\t\telif robot_id:\n\t\t\tlocation_label \u003d \"Robot: {}\".format(robot_id)\n\t\telse:\n\t\t\tlocation_label \u003d \"Location: Unassigned\"\n\n\t\tinstances.append({\n\t\t\t\"containerId\": container_id,\n\t\t\t\"containerType\": container_type,\n\t\t\t\"state\": state,\n\t\t\t\"locationLabel\": location_label,\n\t\t})\n\n\tinstances.sort(key\u003dlambda row: (str(row.get(\"containerType\") or \"\"), str(row.get(\"containerId\") or \"\")))\n\treturn instances",
                  "type": "script"
                }
              ],
              "type": "expr"
            }
          }
        },
