{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 720,
      "width": 1040
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "BannerCard"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "backgroundColor": "#f8fafc",
            "border": "1px solid #cfd6df",
            "borderRadius": "10px",
            "padding": "16px"
          }
        },
        "children": [
          {
            "meta": {
              "hasDelegate": true,
              "name": "BannerTitle"
            },
            "position": {
              "basis": "26px",
              "shrink": 0
            },
            "props": {
              "style": {
                "color": "#475569",
                "fontSize": "13px",
                "fontWeight": "700",
                "textTransform": "uppercase"
              },
              "text": "Main Loop Status"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "BannerStatus"
            },
            "position": {
              "basis": "38px",
              "shrink": 0
            },
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "tagPath": "[Otto_FleetManager]MainControl/Runtime/LoopIsRunning"
                  },
                  "transforms": [
                    {
                      "expression": "if({value}, \"#166534\", \"#991b1b\")",
                      "type": "expression"
                    }
                  ],
                  "type": "tag"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "tagPath": "[Otto_FleetManager]MainControl/Runtime/LoopIsRunning"
                  },
                  "transforms": [
                    {
                      "expression": "if({value}, \"Running\", \"Stopped\")",
                      "type": "expression"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "fontSize": "28px",
                "fontWeight": "700"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "BannerResult"
            },
            "position": {
              "basis": "22px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "tagPath": "[Otto_FleetManager]MainControl/Runtime/LoopLastResult"
                  },
                  "transforms": [
                    {
                      "expression": "\"Last Result: \" + if(isNull({value}) || len(toStr({value})) = 0, \"-\", toStr({value}))",
                      "type": "expression"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "color": "#374151",
                "fontSize": "13px"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "type": "ia.container.flex"
      },
