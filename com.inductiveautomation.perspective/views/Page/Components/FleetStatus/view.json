              {
                "meta": {
                  "name": "RunningValue"
                },
                "position": {
                  "basis": "36px",
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.color": {
                    "binding": {
                      "config": {
                        "expression": "now(2000)"
                      },
                      "transforms": [
                        {
                          "code": "\tresults = system.tag.readBlocking([\n\t\t\"[Otto_FleetManager]MainControl/Runtime/LoopIsRunning\",\n\t\t\"[Otto_FleetManager]MainControl/Runtime/LoopLastResult\"\n\t])\n\tisRunning = bool(results[0].value) if len(results) > 0 and results[0].quality.isGood() else False\n\tlastResult = str(results[1].value or \"\") if len(results) > 1 and results[1].quality.isGood() else \"\"\n\tif lastResult and \"error\" in lastResult.lower():\n\t\treturn \"#991b1b\"\n\tif isRunning:\n\t\treturn \"#166534\"\n\treturn \"#475569\"",
                          "type": "script"
                        }
                      ],
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "now(2000)"
                      },
                      "transforms": [
                        {
                          "code": "\tresults = system.tag.readBlocking([\n\t\t\"[Otto_FleetManager]MainControl/Runtime/LoopIsRunning\",\n\t\t\"[Otto_FleetManager]MainControl/Runtime/LoopLastResult\"\n\t])\n\tisRunning = bool(results[0].value) if len(results) > 0 and results[0].quality.isGood() else False\n\tlastResult = str(results[1].value or \"\") if len(results) > 1 and results[1].quality.isGood() else \"\"\n\tif lastResult and \"error\" in lastResult.lower():\n\t\treturn \"Errored\"\n\tif isRunning:\n\t\treturn \"Running\"\n\treturn \"Idle\"",
                          "type": "script"
                        }
                      ],
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "fontSize": "24px",
                    "fontWeight": "700"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "type": "ia.container.flex"
