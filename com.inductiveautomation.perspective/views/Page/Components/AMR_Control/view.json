              },
              "transforms": [
                {
                  "expression": "\"Not Ready Reason: \" + if(isNull({value}) || len(toStr({value})) = 0, \"-\", toStr({value}))",
                  "type": "expression"
                }
              ],
              "type": "tag"
            }
          }
        },
        "props": {
          "style": {
            "color": "#374151",
            "fontSize": "13px",
