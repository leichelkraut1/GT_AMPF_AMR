{
  "custom": {
    "RVTagName": "AMPF_AMR_RV1"
  },
  "params": {
    "RVNum": 1
  },
  "propConfig": {
    "custom.RVTagName": {
      "binding": {
        "config": {
          "expression": "\"AMPF_AMR_RV\"+{view.params.RVNum}"
        },
        "type": "expr"
      },
      "persistent": true
    },
    "params.RVNum": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 310,
      "width": 320
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Title"
        },
        "position": {
          "basis": "30px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"RV\"+{view.params.RVNum}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "#111827",
            "fontSize": "18px",
            "fontWeight": "700",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Available"
        },
        "position": {
          "basis": "26px",
          "shrink": 0
        },
        "propConfig": {
          "props.style.color": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "1": "{view.params.RVNum}"
                },
                "tagPath": "[Otto_FleetManager]Fleet/Robots/AMPF_AMR_RV{1}/AvailableForWork"
              },
              "transforms": [
                {
                  "expression": "if({value}, \"#166534\", \"#991b1b\")",
                  "type": "expression"
                }
              ],
              "type": "tag"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "1": "{view.params.RVNum}"
                },
                "tagPath": "[Otto_FleetManager]Fleet/Robots/AMPF_AMR_RV{1}/AvailableForWork"
              },
              "transforms": [
                {
                  "expression": "\"Available For Work: \" + if({value}, \"Yes\", \"No\")",
                  "type": "expression"
                }
              ],
              "type": "tag"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "14px",
            "fontWeight": "700"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
