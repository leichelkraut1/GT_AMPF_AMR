      {
        "meta": {
          "name": "WFNumManualDropdown"
        },
        "position": {
          "basis": "42px",
          "shrink": 0
        },
        "propConfig": {
          "props.options": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "direct",
                "tagPath": "[Otto_FleetManager]Fleet/Config/WorkflowConfig"
              },
              "transforms": [
                {
                  "code": "\toptions = [{\"value\": 0, \"label\": \"No manual workflow\"}]\n\toptionsByWorkflow = {}\n\trobotName = \"AMPF_AMR_RV{}\".format(self.view.params.RVNum)\n\tif hasattr(value, \"getRowCount\"):\n\t\tfor rowIndex in range(value.getRowCount()):\n\t\t\trowRobot = str(value.getValueAt(rowIndex, \"RobotName\") or \"\").strip()\n\t\t\tif rowRobot != robotName:\n\t\t\t\tcontinue\n\t\t\ttry:\n\t\t\t\tworkflowNumber = int(value.getValueAt(rowIndex, \"WorkflowNumber\"))\n\t\t\texcept Exception:\n\t\t\t\tcontinue\n\t\t\tif workflowNumber <= 0:\n\t\t\t\tcontinue\n\t\t\tmissionLabel = str(value.getValueAt(rowIndex, \"MissionLabel\") or \"\").strip()\n\t\t\toptionsByWorkflow[workflowNumber] = {\n\t\t\t\t\"value\": workflowNumber,\n\t\t\t\t\"label\": \"WF {} - {}\".format(workflowNumber, missionLabel or \"-\")\n\t\t\t}\n\tfor key in sorted(optionsByWorkflow.keys()):\n\t\toptions.append(optionsByWorkflow[key])\n\treturn options",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "bidirectional": true,
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "1": "{view.params.RVNum}"
                },
                "tagPath": "[Otto_FleetManager]PLC/AMPF_AMR_RV{1}/HMI/WF_NumManual"
              },
              "type": "tag"
            }
          }
        },
        "props": {
          "placeholder": {
            "text": "Select workflow"
          }
        },
        "type": "ia.input.dropdown"
      },
