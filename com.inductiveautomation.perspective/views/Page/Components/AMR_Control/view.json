{
  "custom": {
    "RVTagName": "AMPF_AMR_RV1"
  },
  "params": {
    "RVNum": 1
  },
  "propConfig": {
    "custom.RVTagName": {
      "binding": {
        "config": {
          "expression": "\"AMPF_AMR_RV\"+{view.params.RVNum}"
        },
        "type": "expr"
      },
      "persistent": true
    },
    "params.RVNum": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 75,
      "width": 241
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Checkbox"
        },
        "position": {
          "height": 36,
          "rotate": {
            "anchor": "25% 36%"
          },
          "width": "100%",
          "y": 31
        },
        "propConfig": {
          "props.selected": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "1": "{view.params.RVNum}"
                },
                "tagPath": "[Otto_FleetManager]MainControl/Robots/AMPF_AMR_RV{1}/DisableIgnitionControl"
              },
              "transforms": [
                {
                  "code": "\treturn value",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          }
        },
        "props": {
          "text": "Disable Ignition Control"
        },
        "type": "ia.input.checkbox"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "height": 32,
          "rotate": {
            "anchor": "25% 25%"
          },
          "width": "100%"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"RV\"+{view.params.RVNum}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.coord"
  }
}