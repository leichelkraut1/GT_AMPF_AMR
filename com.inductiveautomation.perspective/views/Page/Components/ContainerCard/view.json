{
  "custom": {},
  "params": {
    "containerId": "",
    "containerType": "",
    "locationLabel": "Location: Unassigned",
    "state": ""
  },
  "propConfig": {
    "params.containerId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.containerType": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.locationLabel": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.state": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 212,
      "width": 244
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ContainerType"
        },
        "position": {
          "basis": "26px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "if(len(trim(toStr({view.params.containerType}))) \u003d 0, \"Container Type: -\", \"Container Type: \" + toStr({view.params.containerType}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--neutral-90)",
            "fontSize": "15px",
            "fontWeight": "700"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "State"
        },
        "position": {
          "basis": "24px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"State: \" + if(len(trim(toStr({view.params.state}))) \u003d 0, \"-\", toStr({view.params.state}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "13px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Location"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "if(len(trim(toStr({view.params.locationLabel}))) \u003d 0, \"Location: Unassigned\", toStr({view.params.locationLabel}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "13px",
            "whiteSpace": "normal",
            "wordBreak": "break-word"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "ContainerId"
        },
        "position": {
          "basis": "42px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"ID: \" + if(len(trim(toStr({view.params.containerId}))) \u003d 0, \"-\", toStr({view.params.containerId}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "color": "var(--neutral-70)",
            "fontSize": "12px",
            "whiteSpace": "normal",
            "wordBreak": "break-word"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tpopupId \u003d \"delete-container-{}\".format(str(self.view.params.containerId or \"unknown\"))\n\tsystem.perspective.openPopup(\n\t\tid\u003dpopupId,\n\t\tview\u003d\"Page/Components/ContainerDeletePopup\",\n\t\tparams\u003d{\n\t\t\t\"containerId\": self.view.params.containerId,\n\t\t\t\"locationLabel\": self.view.params.locationLabel,\n\t\t\t\"popupId\": popupId,\n\t\t},\n\t\ttitle\u003d\"Delete Container\",\n\t\tmodal\u003dTrue,\n\t\toverlayDismiss\u003dFalse,\n\t\tshowCloseIcon\u003dFalse,\n\t\tdraggable\u003dFalse,\n\t)\n"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "DeleteButton"
        },
        "position": {
          "basis": "34px",
          "shrink": 0
        },
        "props": {
          "style": {
            "backgroundColor": "#fef2f2",
            "borderColor": "#fca5a5",
            "color": "#b91c1c"
          },
          "text": "Delete"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "var(--neutral-10)",
        "border": "1px solid var(--neutral-40)",
        "borderRadius": "8px",
        "color": "var(--neutral-90)",
        "boxShadow": "0 1px 2px rgba(0,0,0,0.08)",
        "marginBottom": "16px",
        "marginRight": "16px",
        "padding": "12px"
      }
    },
    "type": "ia.container.flex"
  }
}
