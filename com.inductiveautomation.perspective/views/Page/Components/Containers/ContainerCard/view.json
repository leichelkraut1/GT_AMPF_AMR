{
  "custom": {},
  "params": {
    "containerId": "",
    "containerType": "",
    "locationLabel": "Location: Unassigned",
    "state": "",
    "viewOnly": true
  },
  "propConfig": {
    "custom.themeDividerBorder": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"1px solid #374151\"\n\treturn \"1px solid #d1d5db\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeMutedText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#9ca3af\"\n\treturn \"#6b7280\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themePrimaryText": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#f3f4f6\"\n\treturn \"#111827\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceAltBg": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#1f2937\"\n\treturn \"#f3f4f6\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceBg": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"#111827\"\n\treturn \"#f9fafb\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeSurfaceBorder": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"1px solid #374151\"\n\treturn \"1px solid #d1d5db\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "custom.themeTableDividerBorder": {
      "binding": {
        "config": {
          "path": "session.props.theme"
        },
        "transforms": [
          {
            "code": "\tif \"dark\" in str(value or \"\").lower():\n\t\treturn \"1px solid #4b5563\"\n\treturn \"1px solid #9ca3af\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": false
    },
    "params.containerId": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.containerType": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.locationLabel": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.state": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.viewOnly": {
      "paramDirection": "input",
      "persistent": true
    },
    "props.defaultSize.height": {
      "binding": {
        "config": {
          "expression": "if({view.params.viewOnly},135,212)"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 228
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "ContainerType"
        },
        "position": {
          "basis": "42px",
          "shrink": 0
        },
        "props": {
          "direction": "column"
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "ContainerTypeLabel"
            },
            "position": {
              "basis": "16px",
              "shrink": 0
            },
            "props": {
              "style": {
                "fontSize": "13px"
              },
              "text": "Container Type:"
            },
            "type": "ia.display.label",
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "path": "view.custom.themeMutedText"
                  },
                  "type": "property"
                }
              }
            }
          },
          {
            "meta": {
              "name": "ContainerTypeValue"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "style": {
                "fontSize": "15px",
                "fontWeight": "700",
                "lineHeight": "1.15",
                "whiteSpace": "normal",
                "wordBreak": "break-word"
              }
            },
            "type": "ia.display.label",
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "path": "view.custom.themePrimaryText"
                  },
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(len(trim(toStr({view.params.containerType}))) = 0, \"-\", toStr({view.params.containerType}))"
                  },
                  "type": "expr"
                }
              }
            }
          }
        ]
      },
      {
        "meta": {
          "name": "Location"
        },
        "position": {
          "basis": "35px",
          "shrink": 0
        },
        "props": {
          "alignItems": "baseline",
          "direction": "row",
          "style": {
            "columnGap": "4px"
          }
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "LocationLabel"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "fontSize": "13px"
              }
            },
            "type": "ia.display.label",
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "path": "view.custom.themeMutedText"
                  },
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(len(trim(toStr({view.params.locationLabel}))) = 0, \"Location:\", if(indexOf(toStr({view.params.locationLabel}), \":\") >= 0, left(toStr({view.params.locationLabel}), indexOf(toStr({view.params.locationLabel}), \":\") + 1), \"Location:\"))"
                  },
                  "type": "expr"
                }
              }
            }
          },
          {
            "meta": {
              "name": "LocationValue"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "style": {
                "fontSize": "13px",
                "fontWeight": "700",
                "whiteSpace": "normal",
                "wordBreak": "break-word"
              }
            },
            "type": "ia.display.label",
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "path": "view.custom.themePrimaryText"
                  },
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "if(len(trim(toStr({view.params.locationLabel}))) = 0, \"Unassigned\", if(indexOf(toStr({view.params.locationLabel}), \":\") >= 0, trim(right(toStr({view.params.locationLabel}), len(toStr({view.params.locationLabel})) - indexOf(toStr({view.params.locationLabel}), \":\") - 1)), toStr({view.params.locationLabel})))"
                  },
                  "type": "expr"
                }
              }
            }
          }
        ]
      },
      {
        "meta": {
          "name": "State"
        },
        "position": {
          "basis": "24px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"State: \" + if(len(trim(toStr({view.params.state}))) \u003d 0, \"-\", toStr({view.params.state}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "alignVertical": "bottom",
          "style": {
            "fontSize": "13px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "ContainerId"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.basis": {
            "binding": {
              "config": {
                "expression": "if({view.params.viewOnly}, \"0px\", \"42px\")"
              },
              "type": "expr"
            }
          },
          "position.display": {
            "binding": {
              "config": {
                "expression": "!{view.params.viewOnly}"
              },
              "type": "expr"
            }
          },
          "props.style.color": {
            "binding": {
              "config": {
                "path": "view.custom.themeMutedText"
              },
              "type": "property"
            }
          },
          "props.style.display": {
            "binding": {
              "config": {
                "expression": "if({view.params.viewOnly}, \"none\", \"block\")"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"ID: \" + if(len(trim(toStr({view.params.containerId}))) \u003d 0, \"-\", toStr({view.params.containerId}))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "12px",
            "whiteSpace": "normal",
            "wordBreak": "break-all"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tpopupId \u003d \"delete-container-{}\".format(str(self.view.params.containerId or \"unknown\"))\n\tsystem.perspective.openPopup(\n\t\tid\u003dpopupId,\n\t\tview\u003d\"Page/Components/Dialogs/ContainerDeletePopup\",\n\t\tparams\u003d{\n\t\t\t\"containerId\": self.view.params.containerId,\n\t\t\t\"locationLabel\": self.view.params.locationLabel,\n\t\t\t\"popupId\": popupId,\n\t\t},\n\t\ttitle\u003d\"Delete Container\",\n\t\tmodal\u003dTrue,\n\t\toverlayDismiss\u003dFalse,\n\t\tshowCloseIcon\u003dFalse,\n\t\tdraggable\u003dFalse,\n\t)\n"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "DeleteButton",
          "tooltip": {
            "style": {
              "paddingTop": "5px"
            }
          }
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.basis": {
            "binding": {
              "config": {
                "expression": "if({view.params.viewOnly}, \"0px\", \"34px\")"
              },
              "type": "expr"
            }
          },
          "position.display": {
            "binding": {
              "config": {
                "expression": "!{view.params.viewOnly}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "backgroundColor": "#fef2f2",
            "borderColor": "#fca5a5",
            "color": "#b91c1c",
            "marginTop": "6px"
          },
          "text": "Delete"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.backgroundColor": {
        "binding": {
          "config": {
            "path": "view.custom.themeSurfaceBg"
          },
          "type": "property"
        }
      },
      "props.style.border": {
        "binding": {
          "config": {
            "path": "view.custom.themeSurfaceBorder"
          },
          "type": "property"
        }
      },
      "props.style.color": {
        "binding": {
          "config": {
            "path": "view.custom.themePrimaryText"
          },
          "type": "property"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {
        "borderRadius": "8px",
        "boxShadow": "0 1px 2px rgba(0,0,0,0.08)",
        "marginBottom": "16px",
        "marginRight": "16px",
        "padding": "12px"
      }
    },
    "type": "ia.container.flex"
  }
}
