{
  "custom": {},
  "params": {},
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Title"
            },
            "position": {
              "basis": "0px",
              "grow": 1
            },
            "props": {
              "params": {
                "icon": "dashboard",
                "text": "Status"
              },
              "path": "Page/Embedded/Title"
            },
            "type": "ia.display.view"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\timport Otto_API.Fleet.Refresh\n\tlogger \u003d system.util.getLogger(\"Perspective.StatusPage\")\n\tresult \u003d Otto_API.Fleet.Refresh.refreshFleetData()\n\tlogger.info(\"Refresh Fleet Data - {}\".format(str(result.get(\"message\") or \"completed\")))\n\treturn"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "RefreshFleetDataButton"
            },
            "position": {
              "basis": "170px",
              "shrink": 0
            },
            "props": {
              "style": {
                "marginRight": "8px",
                "marginTop": "0px"
              },
              "text": "Refresh Fleet Data"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "TitleRow"
        },
        "position": {
          "basis": "56px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "hasDelegate": true,
          "name": "Spacer"
        },
        "position": {
          "basis": "12px",
          "shrink": 0
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "FleetStatus"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "path": "Page/Components/Status/FleetStatus"
        },
        "type": "ia.display.view"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "Page/Page"
      }
    },
    "type": "ia.container.flex"
  }
}