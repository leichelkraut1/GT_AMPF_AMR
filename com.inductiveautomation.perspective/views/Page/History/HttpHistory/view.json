              "transforms": [
                {
                  "code": "def value_for_key(selection, key):\n\tif selection is None:\n\t\treturn \"\"\n\ttry:\n\t\tif hasattr(selection, '__len__') and len(selection) == 0:\n\t\t\treturn \"\"\n\texcept Exception:\n\t\tpass\n\trow = selection\n\ttry:\n\t\tif isinstance(selection, list):\n\t\t\trow = selection[0]\n\texcept Exception:\n\t\trow = selection\n\ttry:\n\t\tif hasattr(row, 'get'):\n\t\t\tif row.get(key) is not None:\n\t\t\t\treturn unicode(row.get(key))\n\t\t\tinner = row.get('value')\n\t\t\tif hasattr(inner, 'get') and inner.get(key) is not None:\n\t\t\t\treturn unicode(inner.get(key))\n\texcept Exception:\n\t\tpass\n\ttry:\n\t\tfor cell in selection:\n\t\t\tif not hasattr(cell, 'get'):\n\t\t\t\tcontinue\n\t\t\tname = cell.get('column') or cell.get('field') or cell.get('name')\n\t\t\tif name == key:\n\t\t\t\tcell_value = cell.get('value')\n\t\t\t\tif hasattr(cell_value, 'get') and cell_value.get('value') is not None:\n\t\t\t\t\treturn unicode(cell_value.get('value'))\n\t\t\t\tif cell_value is not None:\n\t\t\t\t\treturn unicode(cell_value)\n\texcept Exception:\n\t\tpass\n\treturn \"\"\n\nreturn value_for_key(value, 'Url')",
                  "type": "script"
