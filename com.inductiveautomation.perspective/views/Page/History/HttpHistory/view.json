                  "transforms": [
                    {
                      "code": "\tmode = str(self.view.custom.selectedDatasetMode or \"all\").strip().lower()\n\tpathByMode = {\n\t\t\"all\": \"[Otto_FleetManager]MainControl/Runtime/HttpHistory\",\n\t\t\"get\": \"[Otto_FleetManager]MainControl/Runtime/HttpGetHistory\",\n\t\t\"post\": \"[Otto_FleetManager]MainControl/Runtime/HttpPostHistory\"\n\t}\n\ttagPath = pathByMode.get(mode, pathByMode[\"all\"])\n\tdatasetValue = system.tag.readBlocking([tagPath])[0].value\n\tif datasetValue is None:\n\t\treturn system.dataset.toDataSet([\"Ts\", \"Method\", \"Url\", \"Request\", \"Response\", \"Ok\", \"DurationMs\", \"Error\"], [])\n\ttry:\n\t\treturn system.dataset.sort(datasetValue, \"Ts\", True)\n\texcept Exception:\n\t\treturn datasetValue",
                      "type": "script"
                    }
                  ],
                  "type": "expr"
                }
              }
